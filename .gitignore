.cursor/mcp.json
**/mcp.local.json

# Python
venv/
.venv/
__pycache__/
*.py[cod]

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Lock files (we use npm, so ignore others)
bun.lockb
yarn.lock
pnpm-lock.yaml

node_modules
dist
dist-ssr
*.local
.vite

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
supabase/functions/.env

# System prompt file (auto-generated, not needed in repo)
current-system-prompt.md
# Local coursework / export artifacts (keep out of repo if present)
ML Portfolio Project.pdf
# Playwright
tests/auth/states/
test-results/
playwright-report/
tests/.env.test

# Supabase health check generated graphs (regenerated from JSON snapshots)
supabase-health/*/graphs/

# Cursor personal config (per-developer, not shared) — copy from .cursorrules.example
.cursorrules

# Knowledge Builder Agent — test credentials and working space
knowledge-agent/.testEnvVars
knowledge-agent/logs/

# Local-only copies under knowledge-agent (root `ai/guides/` is the committed set for grading)
knowledge-agent/.env
knowledge-agent/**/*.local.md

# Capacitor iOS — keep project config, ignore build artifacts
ios/App/Pods/
ios/App/App/public/
ios/App/build/
ios/DerivedData/

# Capacitor Android — keep project config, ignore build artifacts & secrets
android/app/src/main/assets/public/
android/app/src/main/assets/capacitor.config.json
android/app/build/
android/.gradle/
android/build/
android/local.properties
android/key.properties
android/*.keystore
android/app/google-services.json

# Lighthouse reports
Lighthouse_diagnostic.json
lighthouse-pwa.json
